{
  "name": "fb-pilot",
  "version": "1.1.0",
  "description": "Chrome extension for Facebook page management automation",
  "private": true,
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --testPathIgnorePatterns=e2e",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:coverage": "jest --config jest.config.js --coverage --testPathIgnorePatterns=e2e",
    "lint": "eslint content/ background/ popup/ tests/",
    "lint:fix": "eslint --fix content/ background/ popup/ tests/",
    "validate:manifest": "node scripts/validate-manifest.js",
    "generate-icons": "node scripts/generate-icons.js",
    "ci": "npm run lint && npm run validate:manifest && npm run test:coverage"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "puppeteer": "^22.0.0"
  }
}
