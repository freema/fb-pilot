{
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true,
    "jest": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn"
  }
}
